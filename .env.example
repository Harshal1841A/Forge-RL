# FORGE Environment Configuration
# Copy this file to .env and fill in your keys
# ALL keys below are 100% FREE — no credit card required

# ─────────────────────────────────────────────────────────────────────────────
# FORGE-MA MULTI-PROVIDER SETUP (v2.1+)
#
# Each forensic agent uses a DIFFERENT AI to prevent shared-model bias:
#
#   Forensic Auditor   → Groq    / Llama-3 70B   (free at console.groq.com)
#   Context Historian  → Cerebras/ Llama-3.1 70B (free at cloud.cerebras.ai)
#   Narrative Critic   → Mistral / mistral-small  (free at console.mistral.ai)
#   NegotiatedSearch   → OpenRouter / Llama-3 8B (free at openrouter.ai)
#
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Groq — Forensic Auditor ───────────────────────────────────────────────
# Sign up free → https://console.groq.com → API Keys → Create key
OPENAI_API_KEY=your_groq_api_key_here
OPENAI_API_KEY_AUDITOR=your_groq_api_key_here
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama3-70b-8192

# ── 2. Cerebras — Context Historian ──────────────────────────────────────────
# Sign up free → https://cloud.cerebras.ai → API Keys → Create key
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama3.1-70b

# ── 3. Mistral — Narrative Critic ────────────────────────────────────────────
# Sign up free → https://console.mistral.ai → API Keys → Create key
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest

# ── 4. OpenRouter — NegotiatedSearch agents ───────────────────────────────────
# Sign up free → https://openrouter.ai → Keys → Create key (free credits included)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct:free

# ── Per-agent provider routing (change to override defaults) ──────────────────
AGENT_AUDITOR_PROVIDER=groq
AGENT_HISTORIAN_PROVIDER=cerebras
AGENT_CRITIC_PROVIDER=mistral
AGENT_NEGOTIATED_PROVIDER=openrouter

# ── Optional: HuggingFace Token (for embedding models) ───────────────────────
# HF_TOKEN=your_hf_token_here

# ─────────────────────────────────────────────────────────────────────────────
# FREE EXTERNAL TOOL APIs
# ─────────────────────────────────────────────────────────────────────────────

# MediaStack — 500 calls/month free → https://mediastack.com
MEDIASTACK_API_KEY=your_mediastack_api_key_here

# GNews — 100 calls/day free → https://gnews.io
GNEWS_API_KEY=your_gnews_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# SERVER & CACHE CONFIG (defaults are fine for local dev)
# ─────────────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=7860
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./forge.db

# Set to true to disable all live API calls (use cached responses only)
INTERNET_OFF=false

# Optional: custom path for tool response cache DB
FORGE_CACHE_DB=
